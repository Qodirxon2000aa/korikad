{
  "name": "navbat-korik-admin",
  "private": true,
  "version": "1.1.1",
  "description": "Sherdor Ko'rik admin paneli (Windows)",
  "author": "Sherdor Medical",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3003 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently -k \"vite --port 3003 --host 127.0.0.1\" \"wait-on http://127.0.0.1:3003 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:3003 electron .\"",
    "electron:pack": "vite build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "framer-motion": "^12.38.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-toastify": "^11.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.14",
    "vite": "^6.2.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.sherdormedical.navbat.korik.admin",
    "productName": "Sherdor Korik Admin",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sherdor Korik Admin",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}
